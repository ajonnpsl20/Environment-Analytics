# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# NextAuth v5
AUTH_SECRET="generate-via-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Cloudflare R2 — for Waste Transfer Note (WTN) PDF attachments.
# OPTIONAL: leave blank and the app runs fully without attachments (the Waste
# form shows "file storage isn't configured" and records save without a file).
# Filling all four of ACCOUNT_ID/ACCESS_KEY_ID/SECRET_ACCESS_KEY/BUCKET_NAME
# activates uploads automatically — no code change.
#
# Uploads go browser → R2 directly via a presigned PUT URL, so the bucket ALSO
# needs a one-time CORS rule (Cloudflare dashboard → bucket → Settings → CORS):
#   [{ "AllowedOrigins": ["http://localhost:3000", "https://<your-vercel-url>"],
#      "AllowedMethods": ["PUT", "GET"],
#      "AllowedHeaders": ["content-type"] }]
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="envirohub-uploads"
R2_PUBLIC_URL=""
# Jurisdiction for data-residency buckets. Leave BLANK for a standard bucket.
# Set to "eu" if the bucket was created with EU jurisdiction (EU data residency)
# — such a bucket is only reachable via the <account>.eu.r2.cloudflarestorage.com
# endpoint, and the standard endpoint returns 403 AccessDenied for everything.
R2_JURISDICTION=""

# App
NEXT_PUBLIC_APP_NAME="EnviroHub"
